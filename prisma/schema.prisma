// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  PARENT
}

enum TokenType {
  REFRESH
  RESET_PASSWORD
}

// ─────────────────────────────────────────
// SCHOOL (Tenant root)
// ─────────────────────────────────────────

model School {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  email       String   @unique
  phone       String?
  address     String?
  logo        String?
  website     String?
  motto       String?
  
  // Settings
  termName    String   @default("Term")      // "Term" or "Semester"
  resultPin   Boolean  @default(true)        // require scratch card for results
  showPosition Boolean @default(true)        // show class position on result

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Staff signature images for result PDF ──────
  // Stored as base64 data URLs or cloud storage URLs
  teacherSignature    String?   // class teacher signature image
  schoolSeal          String?   // official school seal/stamp image
  principalSignature  String?   // principal's signature image

  users       User[]
  students  Student[]
  classes   Class[] 
  subjects  Subject[] 
  sessions  Session[]
    terms     Term[]
    results      Result[]  
    resultItems  ResultItem[]
     resultSkills ResultSkill[]
     scratchCards ScratchCard[] 
     cardUsages    CardUsage[]  
     parentStudents ParentStudent[] 


  @@map("schools")
}


// ─────────────────────────────────────────
// USER (All roles share this model)
// ─────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  phone       String?
  address     String?
  photo       String?
  role        Role
  isActive    Boolean  @default(true)
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  tokens      Token[]
  students    Student[] @relation("ParentStudents")
    parentLinks  ParentStudent[] @relation("ParentLinks") 

  @@index([schoolId])
  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────
// TOKEN (Refresh tokens stored in DB)
// ─────────────────────────────────────────

model Token {
  id        String    @id @default(cuid())
  token     String    @unique
  type      TokenType @default(REFRESH)
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())

  // Relations
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tokens")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  SUSPENDED
}


// ─────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────

model Student {
  id             String        @id @default(cuid())
  regNumber      String        @unique   // e.g. GFA/2024/001
  firstName      String
  lastName       String
  middleName     String?
  dateOfBirth    DateTime?
  gender         Gender
  photo          String?
  address        String?
  status         StudentStatus @default(ACTIVE)

  // Parent link (optional at creation)
  parentId       String?

  // School (tenant)
  schoolId       String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  school         School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent         User?   @relation("ParentStudents", fields: [parentId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([regNumber])
  @@index([parentId])
  @@index([status])
   @@index([schoolId, status])   // ← ADD composite for filtered lists
  @@map("students")
   results   Result[]
   cardUsages    CardUsage[]  
    parentLinks   ParentStudent[] @relation("StudentLinks")
}


// ─────────────────────────────────────────
// PARENT-STUDENT LINK (many-to-many)
// ─────────────────────────────────────────

model ParentStudent {
  id        String   @id @default(cuid())
  parentId  String
  studentId String
  schoolId  String
  createdAt DateTime @default(now())

  // Relations
  parent    User    @relation("ParentLinks", fields: [parentId],  references: [id], onDelete: Cascade)
  student   Student @relation("StudentLinks", fields: [studentId], references: [id], onDelete: Cascade)
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
  @@index([schoolId])
  @@map("parent_students")
}

// ─────────────────────────────────────────
// CLASS
// ─────────────────────────────────────────

model Class {
  id          String   @id @default(cuid())
  name        String                        // e.g. "JSS 1", "SS 2A"
  description String?
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjects    Subject[]

  @@unique([name, schoolId])               // same class name can't exist twice per school
  @@index([schoolId])
  @@map("classes")
  results   Result[] 
}

// ─────────────────────────────────────────
// SUBJECT
// ─────────────────────────────────────────

model Subject {
  id          String   @id @default(cuid())
  name        String                        // e.g. "Mathematics", "English Language"
  code        String?                       // e.g. "MTH", "ENG"
  classId     String
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  class       Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([name, classId])                // same subject can't exist twice per class
  @@index([classId])
  @@index([schoolId])
  @@map("subjects")
   resultItems  ResultItem[] 
}


// ─────────────────────────────────────────
// ACADEMIC SESSION
// ─────────────────────────────────────────

model Session {
  id          String   @id @default(cuid())
  name        String                        // e.g. "2025/2026"
  isActive    Boolean  @default(false)      // only one active per school
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  school      School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms       Term[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@map("sessions")
  results   Result[] 
  scratchCards  ScratchCard[]
}

// ─────────────────────────────────────────
// TERM
// ─────────────────────────────────────────

enum TermNumber {
  FIRST
  SECOND
  THIRD
}

model Term {
  id          String     @id @default(cuid())
  name        TermNumber                    // FIRST, SECOND, THIRD
  isActive    Boolean    @default(false)    // only one active per school
  sessionId   String
  schoolId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([name, sessionId])               // can't have two "FIRST" terms in same session
  @@index([sessionId])
  @@index([schoolId])
  @@map("terms")
  results   Result[] 
   cardUsages    CardUsage[]  
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Grade {
  A
  B
  C
  P
  F
}

enum SkillRating {
  EXCELLENT   // 5
  GOOD        // 4
  FAIR        // 3
  POOR        // 2
  VERY_POOR   // 1
}

// ─────────────────────────────────────────
// RESULT (one per student per term)
// ─────────────────────────────────────────

model Result {
  id                String   @id @default(cuid())
  studentId         String
  classId           String
  sessionId         String
  termId            String
  schoolId          String

  // Summary (auto-calculated)
  totalScore        Float    @default(0)
  average           Float    @default(0)
  position          Int?
  outOf             Int      @default(0)   // total students in class
  performance       String?               // "Distinction", "Credit" etc

  // Attendance
  daysOpen          Int?
  daysPresent       Int?
  daysAbsent        Int?
  vacationDate      DateTime?
  resumptionDate    DateTime?

  // Comments
  teacherComment    String?
  principalComment  String?
  teacherName       String?
  principalName     String?

  isPublished       Boolean  @default(false)  // controls student visibility
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  student           Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class             Class        @relation(fields: [classId], references: [id])
  session           Session      @relation(fields: [sessionId], references: [id])
  term              Term         @relation(fields: [termId], references: [id])
  school            School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  items             ResultItem[]
  skills            ResultSkill[]

  @@unique([studentId, termId])            // one result per student per term
  @@index([schoolId])
  @@index([classId, termId])
  @@index([studentId])
  @@index([isPublished])                // ← ADD for faster published queries
   @@index([termId]) 
  @@map("results")
}

// ─────────────────────────────────────────
// RESULT ITEM (one per subject per result)
// ─────────────────────────────────────────

model ResultItem {
  id              String  @id @default(cuid())
  resultId        String
  subjectId       String
  schoolId        String

  // Scores
  caScore         Float?               // Continuous Assessment (max 40)
  examScore       Float?               // Exam score (max 60)
  totalScore      Float?               // CA + Exam
  grade           Grade?
  remark          String?              // "Excellent", "Very Good" etc
  description     String?              // "Distinction", "Upper Credit" etc
  positionInClass Int?                 // position in this subject
  classAverage    Float?               // average for this subject in class

  // Relations
  result          Result  @relation(fields: [resultId], references: [id], onDelete: Cascade)
  subject         Subject @relation(fields: [subjectId], references: [id])
  school          School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([resultId, subjectId])      // one item per subject per result
  @@index([resultId])
  @@index([subjectId])
  @@map("result_items")
}

// ─────────────────────────────────────────
// RESULT SKILL (psychomotor + social behaviour)
// ─────────────────────────────────────────

enum SkillCategory {
  PSYCHOMOTOR
  SOCIAL
}

model ResultSkill {
  id         String          @id @default(cuid())
  resultId   String
  schoolId   String
  category   SkillCategory
  name       String          // e.g. "Handwriting", "Punctuality"
  rating     SkillRating?

  // Relations
  result     Result @relation(fields: [resultId], references: [id], onDelete: Cascade)
  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([resultId, name])
  @@index([resultId])
  @@map("result_skills")
}

// ─────────────────────────────────────────
// SCRATCH CARD
// ─────────────────────────────────────────

enum CardStatus {
  ACTIVE      // has remaining uses
  EXHAUSTED   // all 4 uses consumed
  DISABLED    // manually disabled by admin
}

model ScratchCard {
  id          String     @id @default(cuid())
  serial      String     @unique
  pin         String     @unique
  status      CardStatus @default(ACTIVE)
  schoolId    String
  sessionId   String                        // ← locked to a session

  // Usage tracking
  usageCount  Int        @default(0)
  maxUses     Int        @default(4)

  // Optional: pre-assign to a student
  assignedTo  String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  usages      CardUsage[]

  @@index([schoolId])
  @@index([pin])
  @@index([sessionId])
   @@index([serial])
   @@index([status])             // ← ADD for status filtering
  @@map("scratch_cards")
}

// Tracks every individual use of a card
model CardUsage {
  id          String   @id @default(cuid())
  cardId      String
  studentId   String
  termId      String
  schoolId    String
  usedAt      DateTime @default(now())

  // Relations
  card        ScratchCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id])
  term        Term        @relation(fields: [termId], references: [id])
  school      School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([studentId])
  @@map("card_usages")
}