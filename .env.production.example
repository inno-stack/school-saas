# ── Database (use connection pooling in production) ─
DATABASE_URL="postgresql://user:password@host:5432/school_saas_db?sslmode=require&connection_limit=10"

# ── JWT (generate with: openssl rand -base64 64) ───
ACCESS_TOKEN_SECRET="<generate-strong-secret-min-64-chars>"
REFRESH_TOKEN_SECRET="<generate-strong-secret-min-64-chars>"

# ── Token Expiry ───────────────────────────────────
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# ── App ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NODE_ENV="production"